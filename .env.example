# Palomar — Docker Compose Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# ── Required for backend container ─────────────────────────────
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
AIS_API_KEY=

# ── Optional ───────────────────────────────────────────────────

# LTA (Singapore traffic cameras) — leave blank to skip
# LTA_ACCOUNT_KEY=

# Override the backend URL the frontend uses (leave blank for auto-detect)
# NEXT_PUBLIC_API_URL=http://192.168.1.50:8000

# ── AI Layer (Palomar) ────────────────────────────────────────
# All models go through LiteLLM. See https://docs.litellm.ai/docs/providers

# Tier 2: cheap/fast model for anomaly triage (e.g., gemini/gemini-2.0-flash, openai/gpt-4o-mini)
# PALOMAR_TRIAGE_MODEL=gemini/gemini-2.0-flash

# Tier 3: strong model for deep analysis and chat (e.g., anthropic/claude-sonnet-4-5, openai/gpt-4o)
# PALOMAR_ANALYST_MODEL=anthropic/claude-sonnet-4-5

# For local models via Ollama (no API key needed)
# PALOMAR_OLLAMA_BASE_URL=http://localhost:11434
